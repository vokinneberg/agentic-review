                            "get_pull_request_diff",
                            "create_pull_request_review",
                            "get_file_contents",
                            "list_pull_request_commits"
                          ]
                        },
                        "type": "McpServer"
                      }
                    ]
                  },
                  "description": "Reviews code diffs and produces actionable feedback.",
                  "type": "Declarative"
                }
